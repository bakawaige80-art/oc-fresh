# ── BACKEND (Railway) environment variables ───────────────
# Add ALL of these in Railway → your service → Variables

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
PAYSTACK_SECRET_KEY=sk_live_your-key-here
JWT_SECRET=any-long-random-string-change-this
APP_URL=https://your-app.up.railway.app
FRONTEND_URL=https://your-app.vercel.app
ADMIN_EMAIL=your-email@example.com
ADMIN_NAME=OriginCheck Team
COPYLEAKS_EMAIL=your-copyleaks-email
COPYLEAKS_API_KEY=your-copyleaks-key
RESEND_API_KEY=re_your-resend-key
FROM_EMAIL=noreply@origincheck.ng
NODE_ENV=production
PORT=3000

# ── FRONTEND (Vercel) environment variables ───────────────
# Add this ONE variable in Vercel → Settings → Environment Variables

REACT_APP_API_URL=https://your-app.up.railway.app
